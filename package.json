{
  "name": "cf-agentic-launchpad",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "flue dev --target cloudflare",
    "dev:client": "vite",
    "build": "vite build && flue build --target cloudflare",
    "deploy": "npm run build && wrangler deploy --config dist/cf_agentic_launchpad/wrangler.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/sandbox": "^0.12.1",
    "@flue/runtime": "^1.0.0-beta.2",
    "@tanstack/react-router": "^1.131.0",
    "agents": "^0.14.5",
    "hono": "^4.9.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@flue/cli": "^1.0.0-beta.1",
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.103.0"
  }
}
