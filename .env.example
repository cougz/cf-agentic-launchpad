# Copy to .env for local use. Never commit real secrets.
# The .gitignore blocks .env and .env.* (this example file is the exception).
#
# The skeleton needs no secrets. Values below are placeholders for later work
# and for Cloudflare Workers Builds environment configuration.

# Cloudflare account id (used by wrangler / Workers Builds)
CLOUDFLARE_ACCOUNT_ID=
