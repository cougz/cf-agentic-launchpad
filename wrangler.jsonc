{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "cf-agentic-launchpad",
  "main": "./src/worker/index.ts",
  "compatibility_date": "2026-06-20",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  },
  // Declared explicitly so deploys do not emit default-behavior warnings.
  // workers_dev: serve on the <name>.<subdomain>.workers.dev URL.
  // preview_urls: per-version preview URLs (handy with Workers Builds).
  "workers_dev": true,
  "preview_urls": true,

  // Sandbox module (@cloudflare/sandbox): a container-backed Durable Object
  // that executes code and commands in an isolated Linux environment.
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile",
      "instance_type": "lite",
      "max_instances": 1
    }
  ],
  "durable_objects": {
    "bindings": [{ "class_name": "Sandbox", "name": "Sandbox" }]
  },
  "migrations": [{ "new_sqlite_classes": ["Sandbox"], "tag": "v1" }]

  // Additional bindings (KV, AI) are added when modules need them.
  // "ai": { "binding": "AI" },
  // "kv_namespaces": [{ "binding": "KV", "id": "<created-id>" }]
}
